# ── Rust / Cargo ──────────────────────────────────────────────────────────────
/target/
# Cargo.lock IS committed: this crate ships a binary (the engine), so the
# lockfile is pinned for reproducible, auditable builds — important for store
# review and CI.

# ── Local Configurations & Secrets ────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env
*.pem
# Exception for the public Apple App Attest root CA certificate
!config/apple_app_attest_root_ca.pem

# ── VS Code / IDE Metadata ──────────────────────────────────────────────────
.vscode/*
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/tasks.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Operating System Files ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs & Caches ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache
.cache/

# run-lifeline driver screenshots
.driver-shots/

# Capacitor / native build artifacts
native/node_modules/
native/ios/
native/android/
native/plugins/*/dist/
native/plugins/*/node_modules/

# Production secrets — never commit
deploy/.env.production
.env.production
