rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Waitlist: anyone may ADD their own email, no one may read, edit, or delete.
    // Because each email is its own doc keyed by the address, a create-only rule
    // also means a repeat signup is rejected (surfaced in the UI as "already on
    // the list") instead of duplicating. The list itself is never readable from
    // the client — export it from the Firebase console or the Admin SDK.
    match /waitlist/{email} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 3
                    && request.resource.data.email.size() < 254
                    && request.resource.data.keys().hasOnly(['email', 'createdAt', 'source']);
      allow read, update, delete: if false;
    }

    // Everything else is locked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
