{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "firestore.rules", "**/.*", "**/README.md"],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.@(js|css|svg)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
