# ─────────────────────────────────────────────────────────────────────────────
# Lifeline production environment — copy to deploy/.env.production and fill in.
#
#   cp deploy/.env.production.example deploy/.env.production
#
# NEVER commit the filled-in file. deploy/.env.production is git-ignored.
#
# Config keys map to env vars by uppercasing and joining sections with "__":
#   [billing] stripe_secret_key  ->  ANTIGRAVITY__BILLING__STRIPE_SECRET_KEY
# Anything you don't set falls back to config/default.toml.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
# MUST be "production" in prod — it turns on HSTS, strict attestation, and the
# fail-fast guards that refuse to boot on placeholder secrets.
ANTIGRAVITY__AUTH__ENVIRONMENT=production

# Cryptographically-random, >= 32 bytes. Generate with:  openssl rand -hex 48
ANTIGRAVITY__AUTH__SERVER_SECRET=

# ── Database (your Supabase / any Postgres) ──────────────────────────────────
# Supabase: Project Settings -> Database -> Connection string (URI). Use the
# pooled connection (port 6543) for serverless-style hosts, or 5432 direct.
# On Fly, `fly postgres attach` sets DATABASE_URL — copy its value here under
# this key (the app reads ANTIGRAVITY__DATABASE__URL, not DATABASE_URL).
ANTIGRAVITY__DATABASE__URL=postgres://USER:PASSWORD@HOST:5432/postgres

# ── AI coach — device-adaptive ───────────────────────────────────────────────
# Premium phones (>8 GB RAM + capable CPU/GPU) download Gemma and run the coach
# fully ON-DEVICE — no key needed for them. Every other device uses the cloud
# coach below. Pick ONE cloud path (or set both; "auto" prefers open-source):
#
#   provider = auto|openai|anthropic  (default auto)
ANTIGRAVITY__AI__PROVIDER=auto
#
# Option A — cheaper open-source model (recommended for the non-premium path).
# Any OpenAI-compatible host: Together, Groq, OpenRouter, DeepInfra, vLLM.
ANTIGRAVITY__AI__OPENAI_BASE_URL=https://api.together.xyz/v1
ANTIGRAVITY__AI__OPENAI_API_KEY=
ANTIGRAVITY__AI__OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#
# Option B — Anthropic Claude (leave blank if using open-source above).
ANTIGRAVITY__AI__ANTHROPIC_API_KEY=

# ── Billing (your Stripe) ────────────────────────────────────────────────────
# Live keys from dashboard.stripe.com. See deploy/GO-LIVE.md for the exact steps
# to create the two products and the webhook that produces these values.
ANTIGRAVITY__BILLING__STRIPE_SECRET_KEY=sk_live_...
ANTIGRAVITY__BILLING__STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs of the two subscription tiers you create in Stripe:
ANTIGRAVITY__BILLING__PRICE_PRO=price_...
ANTIGRAVITY__BILLING__PRICE_ELITE=price_...
# OR — the simplest path — pre-created Stripe Payment Links (public buy URLs).
# When set, Upgrade opens these directly; no secret key needed to take payment.
# Configure the webhook secret above to auto-grant the tier after purchase.
ANTIGRAVITY__BILLING__PAYMENT_LINK_PRO=https://buy.stripe.com/...
ANTIGRAVITY__BILLING__PAYMENT_LINK_ELITE=https://buy.stripe.com/...
# Expected per-tier price in cents — the webhook grants the tier that matches the
# amount actually paid, so the tier can't be spoofed via the checkout URL.
ANTIGRAVITY__BILLING__AMOUNT_PRO_CENTS=799
ANTIGRAVITY__BILLING__AMOUNT_ELITE_CENTS=1499
# Return URLs — point at your deployed domain:
ANTIGRAVITY__BILLING__SUCCESS_URL=https://app.lifeline.health/billing/success
ANTIGRAVITY__BILLING__CANCEL_URL=https://app.lifeline.health/billing/cancel
ANTIGRAVITY__BILLING__PORTAL_RETURN_URL=https://app.lifeline.health/settings

# Apple in-app purchase verification (only if you sell subscriptions via the iOS
# app instead of/in addition to Stripe web checkout):
ANTIGRAVITY__BILLING__APPLE_SHARED_SECRET=
ANTIGRAVITY__BILLING__APPLE_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt
ANTIGRAVITY__BILLING__APPLE_PRODUCT_PRO=
ANTIGRAVITY__BILLING__APPLE_PRODUCT_ELITE=

# ── App Attest (your Apple Developer account) ────────────────────────────────
ANTIGRAVITY__AUTH__APPLE_TEAM_ID=YOUR_TEAM_ID
ANTIGRAVITY__AUTH__APPLE_BUNDLE_ID=health.lifeline.app

# ── Whoop integration (optional) ─────────────────────────────────────────────
ANTIGRAVITY__INTEGRATIONS__WHOOP_CLIENT_ID=
ANTIGRAVITY__INTEGRATIONS__WHOOP_CLIENT_SECRET=
ANTIGRAVITY__INTEGRATIONS__WHOOP_REDIRECT_URI=https://app.lifeline.health/api/v1/integrations/whoop/callback

# ── Admin dashboard (optional) ───────────────────────────────────────────────
# Leave empty to keep /admin disabled. To enable, set a long random token:
#   openssl rand -hex 32
ANTIGRAVITY__ADMIN__ADMIN_TOKEN=
