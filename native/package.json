{
    "name": "lifeline-native",
    "version": "1.0.0",
    "private": true,
    "description": "Capacitor shells that wrap the Lifeline web app for the App Store and Google Play.",
    "scripts": {
        "add:ios": "cap add ios",
        "add:android": "cap add android",
        "sync": "cap sync",
        "assets": "capacitor-assets generate --iconBackgroundColor '#0e1116' --splashBackgroundColor '#000000' --iconBackgroundColorDark '#0e1116' --splashBackgroundColorDark '#000000'",
        "open:ios": "cap open ios",
        "open:android": "cap open android"
    },
    "dependencies": {
        "@capacitor/core": "^6.1.0",
        "@capacitor/ios": "^6.1.0",
        "@capacitor/android": "^6.1.0",
        "@capacitor/haptics": "^6.0.0",
        "@capacitor/status-bar": "^6.0.0",
        "@capacitor/local-notifications": "^6.1.0",
        "@capacitor/device": "^6.0.0",
        "lifeline-native": "file:./plugins/lifeline-native"
    },
    "devDependencies": {
        "@capacitor/cli": "^6.1.0",
        "@capacitor/assets": "^3.0.5"
    }
}
