<?xml version="1.0" encoding="UTF-8"?>
<!--
  Lifeline — app-level Apple Privacy Manifest (REQUIRED, mandatory since May 2024).

  WHERE THIS GOES: after `npx cap add ios`, copy this file (from native/privacy/) to
    native/ios/App/App/PrivacyInfo.xcprivacy
  and add it to the App target in Xcode (Target → Build Phases → Copy Bundle
  Resources, or just ensure it's in the App/ group). One manifest per target.

  VERIFY BEFORE SUBMIT:
   • This declares what the FIRST-PARTY app collects. Every third-party SDK you
     bundle must ship its OWN PrivacyInfo.xcprivacy (Capacitor plugins included).
   • Health & Fitness is declared as collected/linked because encrypted health
     blobs are transmitted off-device to the vault — even though the server
     stores only ciphertext it cannot read (zero-knowledge). Over-declaring is
     safe; under-declaring gets rejected. Confirm this matches your App Store
     Connect privacy "nutrition" labels exactly (store/PRIVACY_LABELS.md).
   • NSPrivacyTracking is false and there are no tracking domains — the app runs
     no ad SDKs and does no cross-app tracking, so no ATT prompt is required.
   • Required-reason APIs: this lists UserDefaults (used by Capacitor core). If
     your final build uses file-timestamp / disk-space / boot-time / keyboard
     APIs, add their categories + approved reason codes here.
-->
<plist version="1.0">
<dict>
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    <key>NSPrivacyCollectedDataTypes</key>
    <array>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeEmailAddress</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeHealth</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeFitness</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeUserID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePurchaseHistory</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
    </array>
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
