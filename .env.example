# ─────────────────────────────────────────────────────────────────────────────
# Antigravity Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` for local development.
# In production, set these via your platform's secret manager (e.g. GCP Secret Manager,
# Kubernetes secrets, systemd environment, etc.).
#
# Nesting uses double-underscore separator: ANTIGRAVITY__SECTION__KEY
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# ANTIGRAVITY__SERVER__HOST=0.0.0.0
# ANTIGRAVITY__SERVER__PORT=8443

# ── Database ──────────────────────────────────────────────────────────────────
ANTIGRAVITY__DATABASE__URL=postgres://antigravity:password@localhost:5432/lifeline
# ANTIGRAVITY__DATABASE__MAX_CONNECTIONS=20

# ── Authentication ────────────────────────────────────────────────────────────
ANTIGRAVITY__AUTH__APPLE_TEAM_ID=REPLACE_ME
ANTIGRAVITY__AUTH__APPLE_BUNDLE_ID=com.yourcompany.lifeline
# MUST be a cryptographically random string, minimum 32 bytes.
# Generate with: openssl rand -base64 48
ANTIGRAVITY__AUTH__SERVER_SECRET=REPLACE_WITH_CRYPTOGRAPHICALLY_RANDOM_SECRET_MIN_32_BYTES
# "production" or "development"
ANTIGRAVITY__AUTH__ENVIRONMENT=development

# ── AI Proxy ──────────────────────────────────────────────────────────────────
# Required in production. Leave empty for mock responses in development.
ANTIGRAVITY__AI__ANTHROPIC_API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# ANTIGRAVITY__RATE_LIMIT__REQUESTS_PER_SECOND=1
# ANTIGRAVITY__RATE_LIMIT__BURST_SIZE=60

# ── Logging ───────────────────────────────────────────────────────────────────
# Override tracing filter (default: "antigravity=info,axum=info,tower_http=info")
# RUST_LOG=antigravity=debug,axum=debug,tower_http=debug
